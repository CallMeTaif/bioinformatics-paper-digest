---
import Base from '../../layouts/Base.astro';
import { allPapers, getPaper, SUMMARY_SECTIONS, accentVar, formatDate } from '../../lib/papers';

export function getStaticPaths() {
  return allPapers().map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const paper = getPaper(slug!);
if (!paper) return Astro.redirect('/404');

const tag = paper.subfield_tags?.[0] ?? 'bioinformatics';
const isMock = paper.summary_provider === 'mock';
const pdfLink = paper.hosted_pdf_path ?? paper.pdf_original_url ?? paper.original_url;
---
<Base title={`${paper.title} — Paper Digest`} description={paper.summary.tldr}>
  <div id="progress"></div>

  <div class="detail">
    <article>
      <div class="chips" style="margin-bottom:12px;">
        <span class="chip tag" style={`--chip-accent:${accentVar(paper.tag_accent)}`}>{tag}</span>
        <span class="chip diff">{paper.difficulty_level}</span>
        {paper.is_preprint && <span class="chip preprint">preprint · not peer-reviewed</span>}
        <span class="chip ai">AI-generated</span>
      </div>

      <h1>{paper.title}</h1>
      <div class="byline">{(paper.authors ?? []).join(', ')}</div>
      <div class="byline">{paper.venue} · {formatDate(paper.publication_date)}</div>

      <div class="ai-notice">
        {isMock
          ? '⚠️ Placeholder summary — generated by the built-in mock model. Real summaries appear once a Gemini API key is configured.'
          : 'AI-generated summary, written by Gemini from the paper’s full text. Always verify against the original paper.'}
      </div>

      <div class="summary">
        {SUMMARY_SECTIONS.map((s) => (
          <section class={s.key}>
            <h2>{s.label}</h2>
            <p>{paper.summary[s.key]}</p>
          </section>
        ))}
      </div>
    </article>

    <aside class="sidebar">
      <div class="info-panel">
        <dl>
          <dt>Venue</dt><dd>{paper.venue ?? '—'}</dd>
          <dt>Published</dt><dd>{formatDate(paper.publication_date) || '—'}</dd>
          {paper.doi && (<><dt>DOI</dt><dd><a href={`https://doi.org/${paper.doi}`}>{paper.doi}</a></dd></>)}
          <dt>License</dt><dd>{paper.license}</dd>
          <dt>Open access</dt><dd>{paper.oa_status ?? '—'}</dd>
          <dt>Source</dt><dd>{paper.source}</dd>
          <dt>Summarized from</dt><dd>{paper.used_full_text ? 'full text' : 'abstract'}</dd>
        </dl>
        {pdfLink && <a class="btn" href={pdfLink} target="_blank" rel="noopener">Read the original ↗</a>}
      </div>
    </aside>
  </div>

  <script is:inline>
    const bar = document.getElementById('progress');
    const onScroll = () => {
      const h = document.documentElement;
      const pct = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100;
      if (bar) bar.style.width = pct + '%';
    };
    document.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  </script>
</Base>
