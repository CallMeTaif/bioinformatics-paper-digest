# ---- Discovery / metadata sources (no key required, but polite pool emails help) ----
OPENALEX_MAILTO=ai.taif.alharbi@gmail.com   # polite pool email for OpenAlex
CROSSREF_MAILTO=ai.taif.alharbi@gmail.com   # polite pool email for Crossref
SEMANTIC_SCHOLAR_API_KEY=                    # optional, Phase 2
NCBI_API_KEY=                                # optional, for PubMed E-utilities (Phase 2)

# ---- Summarizer (reads full text, writes the 7-section summary) ----
# Behind a swappable interface: change provider/model without touching pipeline code.
SUMMARIZER_PROVIDER=google
SUMMARIZER_MODEL=gemini-3.1-pro-preview
GEMINI_API_KEY=

# ---- Abstract pre-screen (cheap model: reads abstracts, drops off-topic before summarizing) ----
PRESCREEN_ENABLED=true
PRESCREEN_PROVIDER=google
PRESCREEN_MODEL=gemini-flash-lite-latest   # cheap; reuses GEMINI_API_KEY

# ---- Verifier (Phase 2 — different family on purpose) ----
VERIFIER_PROVIDER=anthropic
VERIFIER_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
VERIFY_THRESHOLD=0.8       # min faithfulness score for a 'pass' to auto-publish

# ---- Storage / DB ----
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ---- Pipeline tuning ----
MAX_CANDIDATES=15          # top-N abstracts sent to the pre-screen (Phase 2)
PUBLISH_PER_RUN=3          # target papers published per run
DRY_RUN=true               # true = don't write to DB / call paid APIs; print instead
